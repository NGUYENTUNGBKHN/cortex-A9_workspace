/*
 * uart.h / uart.c — UART0 Driver for DE10-Nano HPS Baremetal
 * 16550-compatible, polling mode
 *
 * HPS clock = 25 MHz (L4_SP_CLK typical after bootloader)
 * Baud = 115200 → Divisor = 25000000 / (16 * 115200) ≈ 14
 */

#ifndef UART_H
#define UART_H

#include <stdint.h>

void    uart_init   (uint32_t base, uint32_t l4_clk_hz, uint32_t baud);
void    uart_putc   (uint32_t base, char c);
void    uart_puts   (uint32_t base, const char *s);
int     uart_getc   (uint32_t base);           /* returns -1 if no data */
void    uart_printf (uint32_t base, const char *fmt, ...);

#endif /* UART_H */
