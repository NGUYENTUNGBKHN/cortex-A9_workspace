/*
 * Linker Script - DE10-Nano HPS Baremetal
 * Target: Cyclone V HPS ARM Cortex-A9
 * Load Address: 0x00000000 (On-chip RAM) or 0x00100000 (SDRAM)
 *
 * Memory Map (Cyclone V HPS):
 *   0x00000000 - 0x0003FFFF : OCRAM (256KB)
 *   0xC0000000 - 0xFFFFFFFF : SDRAM (up to 1GB)
 *   0xFF200000 - 0xFF3FFFFF : Lightweight HPS-to-FPGA AXI Bridge
 *   0xFF700000 - 0xFF7FFFFF : HPS Peripherals (UART, GPIO, Timers, ...)
 */

ENTRY(_start)

MEMORY
{
    OCRAM  (rwx) : ORIGIN = 0x00000000, LENGTH = 256K
    SDRAM  (rwx) : ORIGIN = 0x00100000, LENGTH = 512M
}

/* Use OCRAM for baremetal standalone execution */
REGION_ALIAS("REGION_TEXT",   OCRAM)
REGION_ALIAS("REGION_RODATA", OCRAM)
REGION_ALIAS("REGION_DATA",   OCRAM)
REGION_ALIAS("REGION_BSS",    OCRAM)
REGION_ALIAS("REGION_STACK",  OCRAM)

SECTIONS
{
    . = ORIGIN(OCRAM);

    /* ── Vector Table (must be at 0x0) ───────────────── */
    .vectors :
    {
        KEEP(*(.vectors))
    } > REGION_TEXT

    /* ── Code ─────────────────────────────────────────── */
    .text :
    {
        *(.text.startup)
        *(.text*)
        *(.rodata*)
        . = ALIGN(4);
    } > REGION_TEXT

    /* ── Read-only data ───────────────────────────────── */
    .rodata :
    {
        *(.rodata*)
        . = ALIGN(4);
    } > REGION_RODATA

    /* ── Initialized data (LMA=Flash, VMA=RAM) ────────── */
    _data_lma = LOADADDR(.data);
    .data :
    {
        _data_start = .;
        *(.data*)
        . = ALIGN(4);
        _data_end = .;
    } > REGION_DATA

    /* ── Zero-initialized data ────────────────────────── */
    .bss :
    {
        _bss_start = .;
        *(.bss*)
        *(COMMON)
        . = ALIGN(4);
        _bss_end = .;
    } > REGION_BSS

    /* ── Stack (grows downward from top of OCRAM) ─────── */
    .stack (NOLOAD) :
    {
        . = ALIGN(8);
        _stack_bottom = .;
        . += 0x4000;          /* 16KB stack */
        _stack_top = .;
    } > REGION_STACK

    _end = .;
}
